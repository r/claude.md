# Copy to ~/.config/vault-spooler.env and chmod 600. NEVER commit the real file —
# ~/.claude/.gitignore already ignores *.env, and this .example is the only
# version that belongs in git.
#
# Same split as otel-spooler: the code carries no hostnames or credentials, so
# bin/vault-spooler.py ships unmodified to the public repo and everything
# site-specific lives here.

# WebDAV endpoint scoped to the vault's Inbox/Unprocessed/ — and nothing else.
# The endpoint is deliberately narrow: even a fully compromised laptop key can
# only drop files into a staging folder that a human or the vault agent reviews, never touch a
# canonical vault note.
VAULT_UPSTREAM=https://vault-inbox.example.com

# rclone htpasswd credentials for that endpoint. Use a credential dedicated to
# this queue, not the one Obsidian uses for reading — different blast radius.
VAULT_USER=changeme
VAULT_PASS=changeme

# CA bundle, if the endpoint is behind a private CA.
VAULT_CA=/home/youruser/.claude/tls/ca-chain.pem

# Optional tuning (defaults shown).
#VAULT_QUEUE_DIR=/home/youruser/.claude/vault-queue
#VAULT_FLUSH_INTERVAL=10
#VAULT_MAX_INTERVAL=300
#VAULT_TIMEOUT=15
#VAULT_SENT_RETAIN_DAYS=7
