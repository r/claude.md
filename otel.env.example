# Claude Code OpenTelemetry — copy to ~/.claude/otel.env, fill in, then:
#   chmod 600 ~/.claude/otel.env
#   echo '[ -f ~/.claude/otel.env ] && . ~/.claude/otel.env' >> ~/.bashrc   # or ~/.zshrc / ~/.profile
#
# WHY a shell file and not settings.json: Claude Code's OTel SDK reads these from the process
# environment at startup, BEFORE it applies the `env` block in settings.json/settings.local.json.
# Setting them only in settings JSON does NOT enable telemetry. See docs/OTEL.md.

export CLAUDE_CODE_ENABLE_TELEMETRY=1
export OTEL_METRICS_EXPORTER=otlp
export OTEL_LOGS_EXPORTER=otlp
export OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Your OTLP/HTTP endpoint. Point at a local spooler (bin/otel-spooler.py) or straight at your backend.
export OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Required for Prometheus's OTLP receiver (it rejects delta temporality).
export OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE=cumulative

# --- Only if talking DIRECTLY to a remote/TLS backend (omit when using a local spooler) ---
# Private-CA trust (Node needs this; OTEL_EXPORTER_OTLP_CERTIFICATE alone won't do it):
# export NODE_EXTRA_CA_CERTS=/path/to/your-ca.pem
# Bearer auth (Claude Code sends this header; it does NOT present a client cert / mTLS):
# export OTEL_EXPORTER_OTLP_HEADERS="Authorization=Bearer your-token-here"

# Export cadence (optional; these are the defaults shown).
export OTEL_METRIC_EXPORT_INTERVAL=30000
export OTEL_LOGS_EXPORT_INTERVAL=5000
